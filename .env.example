# --- Supabase (Auth + Postgres) ---
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used to build the public, shareable invoice link (e.g. http://localhost:3000 in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Project Settings → Database → Connection string (use the "Transaction" pooler for serverless)
DATABASE_URL=postgresql://postgres:[email protected]:5432/postgres

# Same project, but the "Session" pooler or direct connection (port 5432, not
# 6543) — Prisma's migration commands need this non-transaction-pooled
# connection; the app itself uses DATABASE_URL above for everything else.
DIRECT_URL=postgresql://postgres:[email protected]:5432/postgres

# --- Plaid ---
# https://dashboard.plaid.com/team-settings/keys
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-or-production-secret
PLAID_ENV=sandbox
# Must be a publicly reachable HTTPS URL that routes to /api/plaid/webhook
PLAID_WEBHOOK_URL=https://your-app-domain.com/api/plaid/webhook

# --- Anthropic (receipt OCR) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Resend (emailing invoices and reports) ---
# https://resend.com/api-keys — both must be set for the "Email invoice" /
# "Email report" buttons to appear. RESEND_FROM_EMAIL must be an address on a
# domain you've verified in Resend (Resend → Domains → add godurgaorganics.com,
# then add the SPF/DKIM/DMARC records it gives you to your domain's DNS).
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL="Durga Organics <payments@godurgaorganics.com>"

# Encrypts Plaid access tokens and Stripe keys at rest. Generate with: openssl rand -hex 32
PLAID_TOKEN_ENCRYPTION_KEY=

# Note: Stripe is connected per-organization from Settings → Integrations inside
# the app (not an env var) — see the README for the webhook setup steps. Receipt
# uploads go to a Supabase Storage bucket named "receipts"; create it in your
# Supabase project (Storage → New bucket, private) before using receipt capture.
